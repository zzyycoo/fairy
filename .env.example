# Google Sheets Web App URL
# 部署步骤：
# 1. 访问 https://script.google.com/
# 2. 创建新项目并粘贴 src/sheets.ts 中的 GOOGLE_APPS_SCRIPT_TEMPLATE 代码
# 3. 保存项目
# 4. 点击"部署" → "新建部署"
# 5. 选择类型：Web 应用
# 6. 执行权限：任何人
# 7. 复制 Web 应用 URL 到下方
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# 其他环境变量（可选）
# VITE_APP_NAME=Fairy React
# VITE_APP_VERSION=2.2.01
